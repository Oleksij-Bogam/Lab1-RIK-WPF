<Window x:Class="Lab1_Survey_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторна 1 — Форма опитування (WPF)"
        Height="420" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Форма опитування"
                   FontSize="20"
                   FontWeight="SemiBold"/>

        <TextBlock x:Name="TxtQuestion"
                   Grid.Row="2"
                   Text="Питання"
                   FontSize="16"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="TxtAnswer"
                 Grid.Row="4"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 FontSize="14"/>

        <DockPanel Grid.Row="6" LastChildFill="True">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="BtnPrev" Content="← Назад" Width="110" Margin="0,0,8,0" Click="BtnPrev_Click"/>
                <Button x:Name="BtnNext" Content="Далі →" Width="110" Margin="0,0,8,0" Click="BtnNext_Click"/>
                <Button x:Name="BtnSave" Content="Зберегти у файл" Width="150" Click="BtnSave_Click"/>
            </StackPanel>

            <TextBlock x:Name="TxtStatus"
                       VerticalAlignment="Center"
                       TextAlignment="Right"/>
        </DockPanel>
    </Grid>
</Window>